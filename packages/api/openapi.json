  "info": {
    "title": "Finnn API",
    "description": "Backend API for Finnn finance tracking",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Health",
      "description": ""
    },
    {
      "name": "Auth",
      "description": ""
    },
    {
      "name": "Workspace Invites",
      "description": ""
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "finnn_session": {
        "type": "apiKey",
        "in": "cookie",
        "name": "finnn_session"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Finn User",
            "maxLength": 100,
            "minLength": 1
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "correct-horse-battery",
            "minLength": 6
          }
        },
        "required": ["name", "email", "password"]
      },
      "SuccessResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          }
        },
        "required": ["success"]
      },
      "ApiErrorDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "Validation failed"
          },
          "error": {
            "type": "string",
            "example": "Bad Request"
          },
          "path": {
            "type": "string",
            "example": "/auth/register"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-05-25T12:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": ["statusCode", "message", "error", "path", "timestamp"]
      },
      "VerifyEmailResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "userId": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f1111"
          }
        },
        "required": ["success", "userId"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "correct-horse-battery",
            "minLength": 1
          }
        },
        "required": ["email", "password"]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f1111"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "example": "Finn User"
          },
          "image": {
            "type": "string",
            "example": "avatar-01",
            "nullable": true
          }
        },
        "required": ["id", "email", "name"]
      },
      "AuthUserResponseDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          }
        },
        "required": ["user"]
      },
      "SessionResponseDto": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean",
            "example": true
          },
          "user": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthUserDto"
              }
            ]
          }
        },
        "required": ["authenticated"]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Finn User",
            "maxLength": 100,
            "minLength": 1
          },
          "image": {
            "type": "string",
            "example": "avatar-01",
            "nullable": true
          }
        },
        "required": ["name"]
      },
      "CreateInviteDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "member@example.com"
          },
          "expiresInDays": {
            "type": "number",
            "default": 7,
            "maximum": 30,
            "minimum": 1
          }
        },
        "required": ["email"]
      },
      "WorkspaceInviteDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f1111"
          },
          "workspaceId": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f2222"
          },
          "email": {
            "type": "string",
            "example": "member@example.com"
          },
          "token": {
            "type": "string",
            "example": "b6f13a6bead..."
          },
          "expiresAt": {
            "type": "string",
            "example": "2026-06-01T12:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": ["id", "workspaceId", "email", "token", "expiresAt"]
      },
      "CreateInviteResponseDto": {
        "type": "object",
        "properties": {
          "invite": {
            "$ref": "#/components/schemas/WorkspaceInviteDto"
          }
        },
        "required": ["invite"]
      },
      "WorkspaceInvitePreviewDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "member@example.com"
          },
          "workspaceName": {
            "type": "string",
            "example": "Personal budget"
          },
          "workspaceId": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f2222"
          },
          "expiresAt": {
            "type": "string",
            "example": "2026-06-01T12:00:00.000Z",
            "format": "date-time"
          }
        },
        "required": ["email", "workspaceName", "workspaceId", "expiresAt"]
      },
      "WorkspaceInvitePreviewResponseDto": {
        "type": "object",
        "properties": {
          "invite": {
            "$ref": "#/components/schemas/WorkspaceInvitePreviewDto"
          }
        },
        "required": ["invite"]
      },
      "AcceptInviteResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "workspaceId": {
            "type": "string",
            "example": "665f5d865ef5a20c0d2f2222"
          }
        },
        "required": ["success", "workspaceId"]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"],
            "example": "ok"
          }
        },
        "required": ["status"]
      }
    }
  }
}
