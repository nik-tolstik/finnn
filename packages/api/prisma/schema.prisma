generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Currency {
  USD
  EUR
  RUB
  BYN
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String?
  name          String?
  image         String?
  avatarStorageKey String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspaces      WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  accounts        Account[]
  createdTransfers TransferTransaction[] @relation("TransferCreatedBy")
  authSessions    AuthSession[]
  authIdentities   AuthIdentity[]
  pendingEmailVerifications PendingEmailVerification[]
  passwordResetCodes PasswordResetCode[]
  telegramBotPreference TelegramBotPreference?
  aiFinanceDrafts AiFinanceDraft[]
  createdScheduledPayments ScheduledPayment[] @relation("ScheduledPaymentCreatedBy")
  assignedScheduledPayments ScheduledPayment[] @relation("ScheduledPaymentAssignedTo")
  scheduledPaymentRecords ScheduledPaymentRecord[] @relation("ScheduledPaymentActionBy")
  scheduledPaymentReminderDeliveries ScheduledPaymentReminderDelivery[]

  @@map("users")
}

model AuthIdentity {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  provider       String
  providerUserId String
  username       String?
  displayName    String?
  photoUrl       String?
  linkedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

model PendingEmailVerification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@index([email])
  @@index([expiresAt])
  @@map("pending_email_verifications")
}

model PasswordResetCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId])
  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_codes")
}

model AuthSession {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Workspace {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String   @unique
  baseCurrency String   @default("BYN")
  ownerId      String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner            User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members          WorkspaceMember[]
  accounts         Account[]
  categories       Category[]
  paymentTransactions PaymentTransaction[]
  transferTransactions TransferTransaction[]
  invites          WorkspaceInvite[]
  debts            Debt[]
  debtTransactions DebtTransaction[]
  scheduledPayments ScheduledPayment[]
  scheduledPaymentRecords ScheduledPaymentRecord[]
  scheduledPaymentReminderDeliveries ScheduledPaymentReminderDelivery[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String    @db.ObjectId
  userId      String    @db.ObjectId
  role        String    @default("member")
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model Account {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  ownerId     String?  @db.ObjectId
  name        String
  balance     String   @default("0")
  initialBalance String   @default("0")
  currency    String   @default("USD")
  description String?
  color       String?
  icon        String?
  archived    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id])
  owner            User?             @relation(fields: [ownerId], references: [id])
  paymentTransactions PaymentTransaction[]
  outgoingTransfers TransferTransaction[] @relation("TransferFromAccount")
  incomingTransfers TransferTransaction[] @relation("TransferToAccount")
  debtTransactions DebtTransaction[]
  scheduledPayments ScheduledPayment[]
  scheduledPaymentRecords ScheduledPaymentRecord[]

  @@index([workspaceId, archived])
  @@index([workspaceId, ownerId, archived, order])
  @@map("accounts")
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  name        String
  type        String
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace           Workspace            @relation(fields: [workspaceId], references: [id])
  paymentTransactions PaymentTransaction[]
  scheduledPayments ScheduledPayment[]
  scheduledPaymentRecords ScheduledPaymentRecord[]

  @@index([workspaceId, type, order])
  @@map("categories")
}

model PaymentTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  accountId   String   @db.ObjectId
  amount      String
  type        String
  description String?
  date        DateTime @default(now())
  categoryId  String?  @db.ObjectId
  createdByAi Boolean? @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  account   Account   @relation(fields: [accountId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  scheduledPaymentRecords ScheduledPaymentRecord[]

  @@index([workspaceId, date])
  @@index([workspaceId, type, date])
  @@index([workspaceId, categoryId, date])
  @@index([workspaceId, accountId, date])
  @@index([accountId, date])
  @@map("transactions")
}

model TransferTransaction {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId   String   @db.ObjectId
  fromAccountId String   @db.ObjectId
  toAccountId   String   @db.ObjectId
  createdById    String?  @db.ObjectId
  amount            String
  toAmount          String
  description       String?
  date              DateTime @default(now())
  createdByAi       Boolean? @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  fromAccount  Account   @relation("TransferFromAccount", fields: [fromAccountId], references: [id])
  toAccount    Account   @relation("TransferToAccount", fields: [toAccountId], references: [id])
  createdBy    User?     @relation("TransferCreatedBy", fields: [createdById], references: [id])

  @@index([workspaceId, date])
  @@index([workspaceId, createdById, date])
  @@index([workspaceId, fromAccountId, date])
  @@index([workspaceId, toAccountId, date])
  @@index([fromAccountId, date])
  @@index([toAccountId, date])

  @@map("transfers")
}

model WorkspaceInvite {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  email       String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, email])
  @@index([expiresAt])
  @@map("workspace_invites")
}

model PendingRegistration {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("pending_registrations")
}

model ExchangeRate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        DateTime
  fromCurrency Currency
  toCurrency   Currency
  rate        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, fromCurrency, toCurrency])
  @@index([date])
  @@index([fromCurrency, toCurrency])
  @@map("exchange_rates")
}

model Debt {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId     String   @db.ObjectId
  type            String
  personName      String
  amount          String
  remainingAmount String
  currency        String
  date            DateTime @default(now())
  status          String   @default("open")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace    Workspace         @relation(fields: [workspaceId], references: [id])
  transactions DebtTransaction[]

  @@index([workspaceId, status])
  @@index([workspaceId, status, date])
  @@index([workspaceId, type, status, date])
  @@map("debts")
}

model DebtTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  debtId      String   @db.ObjectId
  accountId   String?  @db.ObjectId
  type        String
  amount      String
  toAmount    String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  debt      Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  account   Account?  @relation(fields: [accountId], references: [id])

  @@index([workspaceId, date])
  @@index([workspaceId, accountId, date])
  @@index([workspaceId, type, date])
  @@index([debtId])
  @@map("debt_transactions")
}

model TelegramBotPreference {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @unique @db.ObjectId
  telegramChatId    String?
  activeWorkspaceId String?  @db.ObjectId
  defaultAccountByWorkspace Json?
  receiptMode       String   @default("category")
  timezone          String   @default("Europe/Minsk")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([activeWorkspaceId])
  @@map("telegram_bot_preferences")
}

model AiFinanceDraft {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  telegramChatId  String?
  workspaceId     String?   @db.ObjectId
  status          String    @default("pending")
  sourceType      String
  sourceText      String?
  receiptMode     String?
  kind            String?
  payload         Json
  missingFields   String[]
  confidence      Float?
  currentQuestion String?
  expiresAt       DateTime
  committedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status, updatedAt])
  @@index([telegramChatId, status, updatedAt])
  @@index([expiresAt])
  @@map("ai_finance_drafts")
}

model ScheduledPayment {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId        String   @db.ObjectId
  name               String
  amountMode         String
  amount             String?
  amountMin          String?
  amountMax          String?
  currency           String?
  categoryId         String?  @db.ObjectId
  accountId          String?  @db.ObjectId
  assignedUserId     String?  @db.ObjectId
  createdById        String   @db.ObjectId
  scheduleKind       String
  scheduleInterval   Int      @default(1)
  scheduleUnit       String?
  dueDay             Int?
  dueMonth           Int?
  nextDueAt          DateTime
  timezone           String   @default("Europe/Minsk")
  reminderDaysBefore Int[]
  notifyTelegram     Boolean  @default(false)
  notifyEmail        Boolean  @default(false)
  notes              String?
  lastPaidAt         DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  account   Account?  @relation(fields: [accountId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  createdBy User     @relation("ScheduledPaymentCreatedBy", fields: [createdById], references: [id])
  assignedUser User? @relation("ScheduledPaymentAssignedTo", fields: [assignedUserId], references: [id])
  records ScheduledPaymentRecord[]
  reminderDeliveries ScheduledPaymentReminderDelivery[]

  @@index([workspaceId, nextDueAt])
  @@index([assignedUserId, nextDueAt])
  @@index([nextDueAt])
  @@map("scheduled_payments")
}

model ScheduledPaymentRecord {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  scheduledPaymentId String   @db.ObjectId
  workspaceId        String   @db.ObjectId
  transactionId      String?  @db.ObjectId
  dueAt              DateTime
  paidAt             DateTime?
  skippedAt          DateTime?
  amount             String?
  currency           String?
  accountId          String?  @db.ObjectId
  categoryId         String?  @db.ObjectId
  actionById         String   @db.ObjectId
  status             String
  note               String?
  createdAt          DateTime @default(now())

  scheduledPayment ScheduledPayment @relation(fields: [scheduledPaymentId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  transaction PaymentTransaction? @relation(fields: [transactionId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  actionBy User @relation("ScheduledPaymentActionBy", fields: [actionById], references: [id])

  @@index([scheduledPaymentId, dueAt])
  @@index([workspaceId, createdAt])
  @@index([transactionId])
  @@map("scheduled_payment_records")
}

model ScheduledPaymentReminderDelivery {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  scheduledPaymentId String    @db.ObjectId
  workspaceId        String    @db.ObjectId
  userId             String    @db.ObjectId
  dueAt              DateTime
  reminderDate       DateTime
  daysBefore         Int
  channel            String
  status             String
  sentAt             DateTime?
  error              String?
  createdAt          DateTime  @default(now())

  scheduledPayment ScheduledPayment @relation(fields: [scheduledPaymentId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([scheduledPaymentId, dueAt, daysBefore, channel])
  @@index([workspaceId, reminderDate])
  @@index([userId, reminderDate])
  @@map("scheduled_payment_reminder_deliveries")
}
