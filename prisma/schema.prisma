generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Currency {
  USD
  EUR
  BYN
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspaces      WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  accounts        Account[]

  @@map("users")
}

model Workspace {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String   @unique
  icon         String?
  baseCurrency String   @default("BYN")
  ownerId      String   @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  invites      WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  userId      String   @db.ObjectId
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Account {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  ownerId     String?  @db.ObjectId
  name        String
  balance     String   @default("0")
  currency    String   @default("USD")
  description String?
  color       String?
  icon        String?
  archived    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  owner        User?         @relation(fields: [ownerId], references: [id])
  transactions Transaction[]

  @@index([workspaceId, archived])
  @@map("accounts")
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  name        String
  type        String
  color       String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id])
  transactions Transaction[]

  @@map("categories")
}

model Transaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  accountId   String   @db.ObjectId
  amount      String
  type        String
  description String?
  date        DateTime @default(now())
  categoryId  String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  account   Account   @relation(fields: [accountId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])

  transferFrom Transfer? @relation("TransferFrom")
  transferTo   Transfer? @relation("TransferTo")

  @@index([workspaceId, date])
  @@index([workspaceId, accountId, date])
  @@index([accountId, date])
  @@map("transactions")
}

model Transfer {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  fromTransactionId String   @unique @db.ObjectId
  toTransactionId   String   @unique @db.ObjectId
  amount            String
  toAmount          String
  createdAt         DateTime @default(now())

  fromTransaction Transaction @relation("TransferFrom", fields: [fromTransactionId], references: [id])
  toTransaction   Transaction @relation("TransferTo", fields: [toTransactionId], references: [id])

  @@map("transfers")
}

model WorkspaceInvite {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  email       String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("workspace_invites")
}

model PendingRegistration {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("pending_registrations")
}

model ExchangeRate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  date        DateTime
  fromCurrency Currency
  toCurrency   Currency
  rate        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, fromCurrency, toCurrency])
  @@index([date])
  @@index([fromCurrency, toCurrency])
  @@map("exchange_rates")
}
